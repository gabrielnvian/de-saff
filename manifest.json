{
    "manifest_version": 3,
    "name": "De-Saff",
    "version": "2.2.1",
    "description": "A better Helpspot experience",
    "permissions": [
        "activeTab",
        "scripting",
        "storage",
        "contextMenus"
    ],
    "content_scripts": [
        {
            "matches": [
                "https://helpspot.csusm.edu/*"
            ],
            "js": [
                "lib/browser-polyfill.min.js",
                "src/import-settings.js",
                "src/wait-for-cards.js",
                "src/fix-dark-mode.js",
                "src/keyboard-navigation.js",
                "src/content.js",
                "src/show-all-listener.js"
            ],
            "run_at": "document_idle"
        }
    ],
    "icons": {
        "128": "icons/icon128.png"
    },
    "options_ui": {
        "page": "options.html",
        "open_in_tab": true
    },
    "host_permissions": [
        "https://helpspot.csusm.edu/*"
    ],
    "background": {
        "service_worker": "background.js",
        "type": "module"
    },
    "browser_specific_settings": {
        "gecko": {
            "id": "desaff@viancorp.local"
        }
    },
    "web_accessible_resources": [
        {
            "resources": [
                "settings.json"
            ],
            "matches": [
                "https://helpspot.csusm.edu/*"
            ]
        }
    ],
    "action": {
        "default_title": "De-Saff",
        "default_icon": "icons/icon128.png"
    }
}
